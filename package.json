{
  "name": "semantle-solver",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Autonomous Hebrew Semantle (סמנטעל) solver — Playwright (headed) + a local model via Ollama.",
  "scripts": {
    "start": "tsx src/solver.ts",
    "play": "tsx src/solver.ts",
    "play:quiet": "cross-env HEADLESS=true tsx src/solver.ts",
    "build:vectors": "tsx scripts/build-vectors.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "playwright": "1.61.1"
  },
  "devDependencies": {
    "@types/node": "22.20.0",
    "cross-env": "10.1.0",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  }
}
